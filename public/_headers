# Cache headers for Cloudflare Pages.
# If you host elsewhere, map these rules to your platform's format:
#   - Netlify:   netlify.toml  [[headers]] for = "/*"
#   - Vercel:    vercel.json   { "headers": [{ "source": "/...", "headers": [...] }] }

# HTML: short cache, revalidated on every deploy (Astro does not hash HTML filenames).
/*.html
  Cache-Control: public, max-age=0, must-revalidate

# Immutable assets (hashed filenames from Astro/Vite): cache forever.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts: long-term cache (hashed by Astro).
/_astro/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Icons: moderate cache (filenames are stable but may change on redeploy).
/favicon.svg
  Cache-Control: public, max-age=86400
/favicon.ico
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400

# OG image: moderate cache (may be regenerated).
/og-image.png
  Cache-Control: public, max-age=86400
