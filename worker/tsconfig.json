{
  "extends": "astro/tsconfigs/strict",
  "include": [
    "**/*.ts",
    "../src/lib/run.ts",
    "../src/lib/shareCode.ts",
    "../src/lib/shareCardData.ts"
  ],
  "compilerOptions": {
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "skipLibCheck": true
  }
}
